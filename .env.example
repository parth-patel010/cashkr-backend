# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://localhost:27017/devicekart

# Auth
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Mobile / shared client gate (required in production for non-browser clients)
MOBILE_APP_API_KEY=your-mobile-app-api-key

# OTP (2factor.in) — no hardcoded fallbacks in code
TWO_FACTOR_API_KEY=
TWO_FACTOR_TEMPLATE=OTPTEMPLATE

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
